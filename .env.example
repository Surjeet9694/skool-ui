# Skool Flutter App Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

APP_NAME=Skool
APP_ENV=development

# API base URL — must match the FastAPI backend
API_BASE_URL=https://api.skoolapp.com/api/v1

# Timeout settings (milliseconds)
CONNECTION_TIMEOUT_MS=15000
RECEIVE_TIMEOUT_MS=30000

# Sentry (leave empty to disable)
SENTRY_DSN=
